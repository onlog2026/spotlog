# =======================================================
# Spotlog - Variáveis de ambiente
# =======================================================
# Copie este arquivo para .env.local e preencha os valores.
# As variáveis NEXT_PUBLIC_* ficam expostas no browser.
# As outras só ficam no servidor (Edge Functions / API Routes).

# ---- Supabase (OBRIGATÓRIO) ----
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_AQUI

# ---- URL pública do app ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- IA — TODA GRATUITA POR PADRÃO (NENHUMA KEY NECESSÁRIA) ----
# O Spotlog usa uma cascata de providers GRATUITOS/open-source:
#   1) Pollinations.ai (DEFAULT) — gpt-4o-mini equivalente, sem auth, sem custo
#   2) OpenRouter (se OPENROUTER_API_KEY setada) — modelos :free (Llama 3.3 70B, Gemma, Phi)
#      Obter chave grátis em: https://openrouter.ai/keys (free credits + free models)
#   3) Groq (se GROQ_API_KEY setada) — Llama 3.3 70B ultra rápido
#      Obter chave grátis em: https://console.groq.com/keys
#   4) Anthropic (se ANTHROPIC_API_KEY setada) — Claude Haiku 3.5
#      Obter em: https://console.anthropic.com/settings/keys (5 dólares grátis pra novos)
#   5) OpenAI (se OPENAI_API_KEY setada) — pago, último fallback
# Imagens são geradas via Pollinations.ai (modelo Flux, gratuito).
#
# Sobrescreva a ordem (csv) com AI_PROVIDER_ORDER, ex: "openrouter,pollinations,groq"
AI_PROVIDER_ORDER=
OPENROUTER_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- E-mail (OPCIONAL) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=contato@seudominio.com.br

# ---- WhatsApp (OPCIONAL — Evolution API ou Z-API) ----
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ---- Prospecção (OPCIONAL) ----
# Apollo.io — 232M+ contatos B2B, free tier limitado a 25 emails desbloqueados/mês.
# Pegue sua key em https://app.apollo.io/#/settings/integrations/api e cole aqui.
APOLLO_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=
LINKEDIN_COOKIE=

# ---- Webhooks (OPCIONAL) ----
WEBHOOK_SECRET=troque-isto-por-string-aleatoria
