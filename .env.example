# =======================================================
# Spotlog - Variáveis de ambiente
# =======================================================
# Copie este arquivo para .env.local e preencha os valores.
# As variáveis NEXT_PUBLIC_* ficam expostas no browser.
# As outras só ficam no servidor (Edge Functions / API Routes).

# ---- Supabase (OBRIGATÓRIO) ----
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_AQUI

# ---- URL pública do app ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- IA (OPCIONAL — pode configurar pelo painel admin depois) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- E-mail (OPCIONAL) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=contato@seudominio.com.br

# ---- WhatsApp (OPCIONAL — Evolution API ou Z-API) ----
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ---- Prospecção (OPCIONAL) ----
APOLLO_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=
LINKEDIN_COOKIE=

# ---- Webhooks (OPCIONAL) ----
WEBHOOK_SECRET=troque-isto-por-string-aleatoria
